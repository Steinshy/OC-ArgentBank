{
	"info": {
		"_postman_id": "argent-bank-api-collection",
		"name": "Argent Bank API",
		"description": "Complete collection of Argent Bank API endpoints for testing. Import this into HTTPie Desktop for instant access to all endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login - Tony Stark",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Save token to environment variable",
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('token', response.body.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"tony@stark.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/login",
							"host": ["{{baseUrl}}"],
							"path": ["user", "login"]
						},
						"description": "Login with Tony Stark test credentials. The token will be automatically saved to the environment variable 'token'."
					},
					"response": []
				},
				{
					"name": "Login - Steve Rogers",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Save token to environment variable",
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('token', response.body.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"steve@rogers.com\",\n  \"password\": \"password456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/login",
							"host": ["{{baseUrl}}"],
							"path": ["user", "login"]
						},
						"description": "Login with Steve Rogers test credentials. The token will be automatically saved to the environment variable 'token'."
					},
					"response": []
				},
				{
					"name": "Signup New User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"new@user.com\",\n  \"password\": \"newpassword123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/signup",
							"host": ["{{baseUrl}}"],
							"path": ["user", "signup"]
						},
						"description": "Create a new user account with email, password, first name, and last name."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for login and signup"
		},
		{
			"name": "User Profile",
			"item": [
				{
					"name": "Get User Profile",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/profile",
							"host": ["{{baseUrl}}"],
							"path": ["user", "profile"]
						},
						"description": "Fetch authenticated user profile. Requires valid JWT token in {{token}} variable."
					},
					"response": []
				},
				{
					"name": "Update User Profile",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Anthony\",\n  \"lastName\": \"Stark\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/profile",
							"host": ["{{baseUrl}}"],
							"path": ["user", "profile"]
						},
						"description": "Update user's first and last name. Requires valid JWT token."
					},
					"response": []
				}
			],
			"description": "User profile management endpoints"
		},
		{
			"name": "Accounts & Transactions (Phase 2 - Not Yet Implemented)",
			"item": [
				{
					"name": "❌ Get All Accounts",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/accounts",
							"host": ["{{baseUrl}}"],
							"path": ["user", "accounts"]
						},
						"description": "[PHASE 2 - NOT YET IMPLEMENTED] Retrieve all bank accounts for the authenticated user. Requires valid JWT token."
					},
					"response": []
				},
				{
					"name": "❌ Get Account Transactions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/accounts/{{accountId}}/transactions",
							"host": ["{{baseUrl}}"],
							"path": ["user", "accounts", "{{accountId}}", "transactions"]
						},
						"description": "[PHASE 2 - NOT YET IMPLEMENTED] Get all transactions for a specific account. Update {{accountId}} variable with actual account ID from Get All Accounts response."
					},
					"response": []
				},
				{
					"name": "❌ Get Single Transaction",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/accounts/{{accountId}}/transactions/{{transactionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "accounts", "{{accountId}}", "transactions", "{{transactionId}}"]
						},
						"description": "[PHASE 2 - NOT YET IMPLEMENTED] Get details of a specific transaction. Set {{accountId}} and {{transactionId}} variables with actual IDs."
					},
					"response": []
				},
				{
					"name": "❌ Update Transaction - Category Only",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"category\": \"Food\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/accounts/{{accountId}}/transactions/{{transactionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "accounts", "{{accountId}}", "transactions", "{{transactionId}}"]
						},
						"description": "[PHASE 2 - NOT YET IMPLEMENTED] Update only the category field of a transaction. Categories: Food, Shopping, Transportation, Entertainment, Bills, etc."
					},
					"response": []
				},
				{
					"name": "❌ Update Transaction - Notes Only",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notes\": \"Updated transaction notes\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/accounts/{{accountId}}/transactions/{{transactionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "accounts", "{{accountId}}", "transactions", "{{transactionId}}"]
						},
						"description": "[PHASE 2 - NOT YET IMPLEMENTED] Update only the notes field of a transaction."
					},
					"response": []
				},
				{
					"name": "❌ Update Transaction - Both Fields",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"category\": \"Shopping\",\n  \"notes\": \"Updated via HTTPie Desktop\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/user/accounts/{{accountId}}/transactions/{{transactionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "accounts", "{{accountId}}", "transactions", "{{transactionId}}"]
						},
						"description": "[PHASE 2 - NOT YET IMPLEMENTED] Update both category and notes fields of a transaction in a single request."
					},
					"response": []
				}
			],
			"description": "Account and transaction management endpoints (Phase 2 - coming soon)"
		}
