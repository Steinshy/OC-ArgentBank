{
  "name": "argentbank",
  "version": "1.0.0",
  "description": "Argent Bank financial dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "pkill -f \"vite\" || true; pkill -f \"nodemon\" || true; concurrently \"npm run dev\" \"npm run dev:server --prefix Backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,tsx,css,scss}\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.1",
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lighthouse": "^13.0.3",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {}
}
